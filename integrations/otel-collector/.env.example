# Grafana Cloud OTLP credentials (VERIFIED 2026-05-18)
# Endpoint format: https://otlp-gateway-prod-<region>.grafana.net/otlp
# Region examples: ap-northeast-0 (Japan), us-central-0 (US), eu-west-0 (EU)
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-northeast-0.grafana.net/otlp

# Basic Auth: base64(instanceId:apiToken)
# Generate with: echo -n "<instanceId>:<apiToken>" | base64
# Instance ID is numeric (e.g., 1649835)
GRAFANA_BASIC_AUTH=base64-encoded-instanceId-colon-apiToken

# Honeycomb credentials (VERIFIED 2026-05-18)
# Ingest API keys start with hcaik_
HONEYCOMB_API_KEY=hcaik_xxxxxxxxxxxxx
HONEYCOMB_DATASET=fsxn-audit
