# Triple backend credentials (Datadog + Grafana Cloud + Honeycomb)
# Verified working 2026-05-19

# Datadog
DD_API_KEY=your-datadog-api-key
DD_SITE=datadoghq.com

# Grafana Cloud
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp
GRAFANA_BASIC_AUTH=base64-encoded-instanceId-colon-apiToken

# Honeycomb
HONEYCOMB_API_KEY=hcaik_your-ingest-key
HONEYCOMB_DATASET=fsxn-audit
