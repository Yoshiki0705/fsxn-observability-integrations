.private/

# OS
.DS_Store
Thumbs.db

# AWS
.aws-sam/
samconfig.toml
cdk.out/

# Environment
# NOTE: .env.*.example files (e.g. integrations/otel-collector/.env.mackerel.example)
# ARE meant to be committed as templates for readers to `cp` and fill in — this
# blanket .env.* rule catches them too. They are force-tracked individually
# via `git add -f <file>` when added (see AGENTS.md → "Adding a New Vendor
# Integration"). If `git status` shows a new .env.*.example as untracked
# after adding one, that's expected — force-add it, don't loosen this rule.
.env
.env.*
.env.local
*.pem

# Build artifacts
*.zip
*.tar.gz

# NetApp Console screenshots (contain real resource IDs, require masking before commit)
integrations/netapp-console/system-manager/screenshots/
.playwright-mcp/
shared/python/dist/

# CloudFormation parameter files (contain account-specific values)
cfn-params/*.json
!cfn-params/*.example.json
!cfn-params/README.md
